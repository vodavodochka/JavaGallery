<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="org.example.demo.GalleryController">
    <top>
        <VBox spacing="10.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="12.0" right="12.0" bottom="8.0" left="12.0"/>
            </padding>
            <HBox spacing="8.0" alignment="CENTER_LEFT">
                <Label text="Сортировка:"/>
                <ComboBox fx:id="sortComboBox" prefWidth="200.0"/>
                <Button text="Загрузить изображение" onAction="#onUploadImage"/>
            </HBox>
            <HBox spacing="8.0" alignment="CENTER_LEFT">
                <Label text="Новое имя:"/>
                <TextField fx:id="renameField" promptText="Введите новое имя" prefWidth="260.0"/>
                <Button text="Переименовать выбранное" onAction="#onRenameSelected"/>
            </HBox>
            <Label fx:id="statusLabel" textFill="#333333" style="-fx-font-size: 11;"/>
        </VBox>
    </top>
    <center>
        <ScrollPane fitToWidth="true" pannable="true" BorderPane.alignment="CENTER">
            <content>
                <TilePane fx:id="thumbnailsPane" hgap="12.0" vgap="12.0" prefColumns="4">
                    <padding>
                        <Insets top="12.0" right="12.0" bottom="12.0" left="12.0"/>
                    </padding>
                </TilePane>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
